{
  "name": "flowmate",
  "version": "0.1.0",
  "private": true,
  "description": "FlowMate - Visual Workflow Builder for Non-Technical Teams",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r --parallel run start",
    "db:push": "pnpm --filter @flowmate/api run db:push",
    "db:migrate": "pnpm --filter @flowmate/api run db:migrate"
  },
  "engines": {
    "node": ">=20"
  }
}
