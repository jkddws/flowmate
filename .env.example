# FlowMate Environment Variables

# Database (required)
DATABASE_URL=postgresql://flowmate:password@localhost:5432/flowmate

# API
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# OpenAI (for AI workflow generation)
OPENAI_API_KEY=

# Integrations (optional)
SLACK_WEBHOOK_URL=
STRIPE_API_KEY=
